# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
# MySQL connection string for Prisma
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Production: Use Railway MySQL instance
DATABASE_URL="mysql://root:password@localhost:3306/afriresearch"

# ─────────────────────────────────────────────
# NextAuth.js
# ─────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
# Full URL of your deployment
NEXTAUTH_URL="http://localhost:3000"

# ─────────────────────────────────────────────
# Email (Resend)
# ─────────────────────────────────────────────
# API key from resend.com
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxx"
# Address used as the From field
RESEND_FROM_EMAIL="noreply@insightafriresearch.com"
# Where admin notifications are delivered
ADMIN_EMAIL="insightafri@gmail.com"

# ─────────────────────────────────────────────
# Image Storage
# ─────────────────────────────────────────────
# Token for Vercel Blob (image uploads)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxxxx"

# ─────────────────────────────────────────────
# Site
# ─────────────────────────────────────────────
# Canonical origin for SEO and OG tags
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Insight AfriResearch Ltd"
